{
  "name": "@yorab/react-paint",
  "version": "0.17.1",
  "type": "module",
  "sideEffects": false,
  "keywords": [
    "react",
    "canvas",
    "whiteboard",
    "image annotation",
    "drawing",
    "annotation",
    "paint"
  ],
  "description": "An open-source canvas-based library for React used for image annotation or as a digital whiteboard.",
  "homepage": "https://yorab.github.io/react-paint-editor",
  "repository": {
    "type": "git",
    "url": "https://github.com/yorab/react-paint-editor.git"
  },
  "bugs": {
    "url": "https://github.com/yorab/react-paint-editor/issues"
  },
  "author": "Yohann Rabatel",
  "license": "MIT",
  "packageManager": "pnpm@10.20.0",
  "main": "./dist/react-paint.umd.cjs",
  "module": "./dist/react-paint.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/react-paint.js",
      "require": "./dist/react-paint.umd.cjs"
    },
    "./canvas": {
      "types": "./dist/canvas/index.d.ts",
      "import": "./dist/canvas/index.js"
    },
    "./editor": {
      "types": "./dist/editor/index.d.ts",
      "import": "./dist/editor/index.js"
    },
    "./react-paint.css": "./dist/react-paint.css"
  },
  "typesVersions": {
    "*": {
      "canvas": [
        "./dist/canvas/index.d.ts"
      ],
      "editor": [
        "./dist/editor/index.d.ts"
      ]
    }
  },
  "files": [
    "README.md",
    "LICENSE.txt",
    "package.json",
    "dist/"
  ],
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@storybook/addon-docs": "10.3.1",
    "@storybook/addon-links": "10.3.1",
    "@storybook/addon-vitest": "10.3.1",
    "@storybook/react-vite": "10.3.1",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "jsdom": "29.0.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "storybook": "10.3.1",
    "typescript": "5.9.3",
    "vite": "8.0.1",
    "vitest": "4.1.0",
    "playwright": "1.58.2",
    "@vitest/browser-playwright": "4.1.0",
    "@vitest/coverage-v8": "4.1.0"
  },
  "peerDependencies": {
    "react": "18.x",
    "react-dom": "18.x"
  },
  "scripts": {
    "declarationfiles": "pnpm tsc --project tsconfig.prod.json && node fixDtsPath.js",
    "start": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest",
    "build": "rm -rf dist && vite build --config vite.config.umd.ts && vite build",
    "lint": "pnpm biome check --write src stories tests",
    "prepublishOnly": "pnpm build && pnpm declarationfiles",
    "publishnpm": "pnpm publish --access public"
  }
}
